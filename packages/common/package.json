{
  "name": "@radiator/common",
  "version": "0.1.0",
  "description": "Shared types, hashing, and serialization for Radiator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@babel/parser": "^7.20.0"
  },
  "peerDependenciesMeta": {
    "@babel/parser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/parser": "^7.26.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
